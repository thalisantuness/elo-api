            "method": "GET",
            "url": {
              "raw": "{{base_url}}/produtos",
              "host": ["{{base_url}}"],
              "path": ["produtos"],
              "query": [
                {
                  "key": "tipo_produto",
                  "value": "eletronico",
                  "disabled": true
                },
                {
                  "key": "tipo_comercializacao",
                  "value": "venda",
                  "disabled": true
                }
              ]
            }
          },
          "response": []
