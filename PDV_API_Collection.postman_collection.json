              "mode": "raw",
              "raw": "{\n  \"nome\": \"Smartphone Samsung\",\n  \"valor\": 1200.00,\n  \"valor_custo\": 800.00,\n  \"quantidade\": 10,\n  \"tipo_comercializacao\": \"venda\",\n  \"tipo_produto\": \"eletronico\",\n  \"estado_id\": 1,\n  \"foto_principal\": \"data:image/jpeg;base64,/9j/4AAQSkZJRgABAQAAAQABAAD...\",\n  \"fotos_secundarias\": [\n    \"data:image/jpeg;base64,/9j/4AAQSkZJRgABAQAAAQABAAD...\",\n    \"data:image/jpeg;base64,/9j/4AAQSkZJRgABAQAAAQABAAD...\"\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/produtos",
              "host": ["{{base_url}}"],
              "path": ["produtos"]
            },
            "description": "Cria um novo produto. Se S3 falhar, fotos são salvas como base64 no banco."
          },
          "response": []
        },
