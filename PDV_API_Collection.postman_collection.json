    {
      "name": "Usuários",
      "item": [
        {
          "name": "Listar Usuários",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/usuarios",
              "host": ["{{base_url}}"],
              "path": ["usuarios"]
            },
            "description": "Lista usuários baseado no role do usuário logado:\n- Admin: Vê todos os usuários (incluindo outros admins)\n- Empresa: Vê empresas e clientes (não vê admins)\n- Cliente: Vê apenas empresas (não vê admins nem outras empresas)"
          },
          "response": []
        },
        {
          "name": "Buscar Usuário por ID",
